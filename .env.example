# ===========================================
# The Card Seeker - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="The Card Seeker"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe (for premium subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_ANNUAL=price_...

# External APIs
# TCGdex - NO API KEY NEEDED (free, open source)
# Limitless TCG - NO API KEY NEEDED (free for most endpoints)
# Only add keys below if you need them for specific use cases

# PokemonPriceTracker (optional - for additional pricing data)
# POKEMON_PRICE_TRACKER_API_KEY=your_pricetracker_key

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM="The Card Seeker <noreply@thecardseeker.com>"

# Error Tracking
NEXT_PUBLIC_SENTRY_DSN=https://...

# Cron Security
CRON_SECRET=your_random_secret_here

# Feature Flags
NEXT_PUBLIC_ENABLE_AI_GENERATION=false
NEXT_PUBLIC_ENABLE_COLLECTION=false
NEXT_PUBLIC_ENABLE_PREMIUM=false
