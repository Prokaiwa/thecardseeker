  "animations": {
    "idle": {
      "name": "Idle Breathing",
      "description": "Subtle scale pulse to show life",
      "properties": {
        "transform": "scale",
        "values": [1.0, 1.02, 1.0],
        "duration": "3s",
        "easing": "ease-in-out",
        "loop": true
      },
      "antenna": {
        "transform": "rotate",
        "values": ["-2deg", "2deg", "-2deg"],
        "duration": "4s",
        "easing": "ease-in-out",
        "loop": true
      }
    },
    
    "searching": {
      "name": "Active Search",
      "description": "Energetic wiggle and glow",
      "antenna": {
        "transform": "rotate",
        "values": ["-15deg", "15deg"],
        "duration": "0.3s",
        "easing": "ease-in-out",
        "loop": true
      },
      "screen": {
        "filter": "brightness",
        "values": [1.0, 1.1, 1.0],
        "duration": "0.8s",
        "loop": true
      },
      "body": {
        "transform": "rotate",
        "values": ["-1deg", "1deg"],
        "duration": "0.2s",
        "loop": true
      }
    },
    
    "celebrating": {
      "name": "Celebration Bounce",
      "description": "Happy bouncing with arms up",
      "body": {
        "transform": "translateY",
        "values": ["0", "-8px", "0"],
        "duration": "0.4s",
        "easing": "cubic-bezier(0.34, 1.56, 0.64, 1)",
        "iterations": 3
      },
      "sparkles": {
        "type": "particle-emit",
        "count": 5,
        "spread": "radial",
        "colors": ["#FFD93D", "#FFF", "#E8C547"]
      }
    },
    
    "transition": {
      "name": "Expression Change",
      "description": "Smooth transition between states",
      "screen": {
        "opacity": [1, 0.8, 1],
        "duration": "0.15s"
      }
    }
  },

